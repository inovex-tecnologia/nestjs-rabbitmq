{
    "name": "@inovex.tecnologia/nestjs-rabbitmq",
    "version": "0.1.4",
    "description": "Integracao RabbitMQ para NestJS: Connection por vhost (estilo @VHostX), publisher com confirm e um BaseListener abstrato com topologia/DLQ/ack automatico.",
    "license": "MIT",
    "author": "Inovex Tecnologia",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/inovex-tecnologia/nestjs-rabbitmq.git"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "rimraf dist && tsc -p tsconfig.build.json",
        "format": "prettier --write \"src/**/*.ts\"",
        "lint": "tsc -p tsconfig.json --noEmit",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "nestjs",
        "rabbitmq",
        "amqp",
        "amqplib",
        "vhost",
        "consumer",
        "publisher"
    ],
    "peerDependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "amqplib": "^0.10.0",
        "reflect-metadata": "^0.2.0"
    },
    "devDependencies": {
        "@nestjs/common": "^11.1.15",
        "@nestjs/config": "^4.0.2",
        "@types/amqplib": "^0.10.5",
        "@types/node": "^24.11.0",
        "amqplib": "^0.10.5",
        "prettier": "^3.6.2",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.2"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "packageManager": "pnpm@11.5.2"
}
